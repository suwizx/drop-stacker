{
	"schemaVersion": 1,
	"id": "drop-stacker",
	"version": "${version}",
	"name": "Drop Stacker",
	"description": "Automatically merges dropped item entities on the ground into stacked entities, reducing item lag on servers and singleplayer worlds.",
	"authors": [
		"suwizx"
	],
	"contact": {
		"homepage": "https://github.com/suwizx/drop-stacker",
		"sources": "https://github.com/suwizx/drop-stacker",
		"issues": "https://github.com/suwizx/drop-stacker/issues"
	},
	"license": "MIT",
	"icon": "assets/drop-stacker/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "dev.suwizx.dropstacker.DropStacker",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "dev.suwizx.dropstacker.client.DropStackerClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "dev.suwizx.dropstacker.client.DropStackerDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"drop-stacker.mixins.json",
		{
			"config": "drop-stacker.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
